# Copy to .env and fill in your values. .env is gitignored.
#
# Tauri updater signing (required for `pnpm tauri build` to produce .sig files)
# Generate with: pnpm tauri signer generate -w ~/.tauri/novelist.key -f -p '' --ci
# Then copy the file contents here:

TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
